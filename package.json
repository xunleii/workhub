{
  "name": "workhub",
  "version": "0.1.0",
  "description": "Local-first CLI for managing Git worktrees grouped into persistent workspaces",
  "type": "module",
  "bin": {
    "wh": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@clack/prompts": "1.2.0",
    "commander": "14.0.3",
    "js-yaml": "4.1.1",
    "simple-git": "3.36.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0",
    "vitest": "4.1.4"
  }
}
